{
  "name": "auth-service",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p .",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "openapi:dump": "tsx src/scripts/dumpOpenapi.ts",
    "create-client": "tsx src/scripts/createClient.ts",
    "grant-admin": "tsx src/scripts/grantAdmin.ts",
    "mcp": "tsx src/mcp/server.ts",
    "mcp:start": "node dist/mcp/server.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^5.18.0",
    "@simplewebauthn/server": "^10.0.0",
    "argon2": "^0.40.3",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^5.1.0",
    "ioredis": "^5.4.1",
    "jose": "^5.6.3",
    "otplib": "^12.0.1",
    "prisma": "^5.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  }
}
