# Origin of the auth API. Used by Next.js Route Handlers (server-side proxy).
# Not exposed to the browser — login/register are server-side calls so the
# refresh token can be set as an httpOnly cookie.
AUTH_API_URL=https://auth.myauthservice.com

# Public site origin. Used for absolute links in emails-preview etc.
NEXT_PUBLIC_SITE_URL=https://myauthservice.com

# Local dev defaults (override in .env.local):
# AUTH_API_URL=http://localhost:8080
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
