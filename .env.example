DATABASE_URL=postgresql://auth:auth@localhost:5432/auth?schema=public
REDIS_URL=redis://localhost:6379

# 32-byte base64 key used to encrypt secrets at rest (TOTP secrets, signing privkeys)
APP_ENCRYPTION_KEY=

# JWT
JWT_ISSUER=https://auth.yourco.local
JWT_AUDIENCE=yourco-services
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# Public origin of the frontend. Used in outgoing email links
# (verify-email, password reset). Must NOT include a trailing slash.
WEB_BASE_URL=https://yourco.local

# Email service (mailnowapi). Templates are created in mailnowapi UI and
# referenced by UUID; logical names map to IDs below.
EMAIL_SERVICE_URL=https://mailnowapi.com
EMAIL_SERVICE_TOKEN=
EMAIL_SERVICE_FROM=noreply@yourdomain.com
VERIFY_EMAIL_TEMPLATE_ID=
PASSWORD_RESET_TEMPLATE_ID=
NEW_DEVICE_LOGIN_TEMPLATE_ID=
EMAIL_CHANGE_TEMPLATE_ID=
ACCOUNT_DELETION_TEMPLATE_ID=
MAGIC_LINK_TEMPLATE_ID=
# Sent to the legitimate account holder when someone tries to register again
# with their email. Contains login + password-reset links so the real owner
# always has a path forward, without leaking account existence to the caller.
REGISTER_EXISTING_ACCOUNT_TEMPLATE_ID=

PORT=8080
LOG_LEVEL=info

# Compromised-password check (haveibeenpwned k-anonymity API).
# Disabled by default; flip to true once you've decided on a threshold.
# HIBP_ENABLED=true
# HIBP_THRESHOLD=1        # block any breach match (1 = strictest)
# HIBP_TIMEOUT_MS=2000    # fail-open on timeout / non-200

# Email retry worker. When enabled, the API process drains the PendingEmail
# queue on a timer. Off by default; turn on in any real deployment.
# EMAIL_WORKER_ENABLED=true
# EMAIL_WORKER_POLL_MS=15000

# New-device sign-in notification email. Off by default.
# NEW_DEVICE_EMAIL_ENABLED=true
# NEW_DEVICE_WINDOW_DAYS=90

# WebAuthn / Passkeys
# - WEBAUTHN_RP_ID: defaults to the JWT_ISSUER host. Set this to a parent
#   domain (e.g. "yourco.local") to share passkeys across subdomains.
# - WEBAUTHN_RP_NAME: shown by some platform credential prompts.
# - WEBAUTHN_ORIGINS: comma-separated origins the browser may legitimately
#   call from. Defaults to WEB_BASE_URL.
# WEBAUTHN_RP_ID=yourco.local
# WEBAUTHN_RP_NAME=YourCo Auth
# WEBAUTHN_ORIGINS=https://yourco.local,https://app.yourco.local

# CORS — comma-separated origins allowed to call the API directly from a
# browser. Leave empty in production if you proxy all browser calls through
# a server-side BFF (Next.js Route Handlers, etc).
# CORS_ALLOW_ORIGINS=https://myauthservice.com,https://www.myauthservice.com

# When true, POST /v1/register rejects callers without a valid service-to-service
# bearer (401 service_token_required). Recommended once every integrator forwards
# its s2s token; prevents silent fallback to the auth service's own email branding
# (verification email from noreply@<auth-host>, links pointing at WEB_BASE_URL)
# when an integrator forgets the Authorization header.
# REGISTER_REQUIRE_SERVICE_TOKEN=true
