DATABASE_URL=postgresql://auth:auth@localhost:5432/auth?schema=public
REDIS_URL=redis://localhost:6379

# 32-byte base64 key used to encrypt secrets at rest (TOTP secrets, signing privkeys)
APP_ENCRYPTION_KEY=

# JWT
JWT_ISSUER=https://auth.yourco.local
JWT_AUDIENCE=yourco-services
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# Public origin of the frontend. Used in outgoing email links
# (verify-email, password reset). Must NOT include a trailing slash.
WEB_BASE_URL=https://yourco.local

# Email service (mailnowapi). Templates are created in mailnowapi UI and
# referenced by UUID; logical names map to IDs below.
EMAIL_SERVICE_URL=https://mailnowapi.com
EMAIL_SERVICE_TOKEN=
EMAIL_SERVICE_FROM=noreply@yourdomain.com
VERIFY_EMAIL_TEMPLATE_ID=
PASSWORD_RESET_TEMPLATE_ID=

PORT=8080
LOG_LEVEL=info

# Compromised-password check (haveibeenpwned k-anonymity API).
# Disabled by default; flip to true once you've decided on a threshold.
# HIBP_ENABLED=true
# HIBP_THRESHOLD=1        # block any breach match (1 = strictest)
# HIBP_TIMEOUT_MS=2000    # fail-open on timeout / non-200

# Email retry worker. When enabled, the API process drains the PendingEmail
# queue on a timer. Off by default; turn on in any real deployment.
# EMAIL_WORKER_ENABLED=true
# EMAIL_WORKER_POLL_MS=15000

# CORS — comma-separated origins allowed to call the API directly from a
# browser. Leave empty in production if you proxy all browser calls through
# a server-side BFF (Next.js Route Handlers, etc).
# CORS_ALLOW_ORIGINS=https://myauthservice.com,https://www.myauthservice.com
